{
  "extends": "@2min.today/typescript-config/base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@lib/*": ["../lib/src/*"],
      "@config/*": ["../config/*"],
      "@data/*": ["../data/*"],
      "@utils": ["../utils/index.ts"],
      "@utils/*": ["../utils/*"]
    }
  },
  "include": ["*.ts", "src/**/*.ts"]
}
