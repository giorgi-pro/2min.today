# apps/web — Vite/SvelteKit loads .env* from this directory (default envDir is apps/web).
# Copy to .env and fill in. Run dev/build from repo root: pnpm dev, pnpm build, etc.

# --- Node ---
# Local .env: use development. Vite sets the same when you run `pnpm dev`; keeping it here makes NODE_ENV visible to any code that loads before Vite.
# Production: hosts (e.g. Vercel) set NODE_ENV=production — never use development in a deployed secrets file.
NODE_ENV="development"

# --- Logging (Pino: digest / breaking / sources routes) ---
# LOG_LEVEL: pino level (default: info). Use debug for embed batches and per-cluster summarize/classify lines.
#
# Pretty logs (pino-pretty): default ON when NODE_ENV is development or local (unset LOG_PRETTY). Default OFF in production (JSON lines).
# LOG_PRETTY=1 or true: pretty in any environment (including production). LOG_PRETTY=0 or false: plain JSON everywhere.
LOG_LEVEL="info"
LOG_PRETTY="1"

# --- Gemini (text + embeddings) — ADR-001 ---
GEMINI_API_KEY="***************************"
FLASH_MODEL="gemini-2.5-flash"
# Optional Flash generateContent tuning (summarize, classify Emerging label, breaking cards — not embeddings).
# FLASH_GENERATION_TEMPERATURE="0.5"
# Gemini 2.5 thinking: token budget; 0 = minimal, -1 = model default (dynamic). See https://ai.google.dev/gemini-api/docs/thinking
# FLASH_THINKING_BUDGET="0"
# Gemini 3+ style: MINIMAL | LOW | MEDIUM | HIGH — can error on 2.5 if used without model support; prefer BUDGET on 2.5 Flash.
# FLASH_THINKING_LEVEL="LOW"
EMBEDDING_MODEL="gemini-embedding-2-preview"
# Must match vector(N) in apps/web/supabase/migrations/001-pgvector.sql unless you migrate.
EMBEDDING_DIMENSION="768"
# Optional: ConstrainedFlow — set to positive ms for paced Flash calls + 429 retries (15s = ~4 RPM, safe for free tier).
# Unset or empty = UnconstrainedFlow — no pacing, no retries (use with billing / high RPM quota).
FLASH_GENERATION_MIN_INTERVAL_MS="15000"
# Optional: max clusters to send through Flash summarize (unset = all). Each cluster is still one generateContent call. Use e.g. 3 to debug stuck summarize.
# DIGEST_SUMMARIZE_MAX_CLUSTERS="3"
# Cosine similarity (0–1) for bucket vs anchor: at/above = fixed bucket; below = Emerging (stored but hidden on homepage).
# CLASSIFY_SIMILARITY_THRESHOLD="0.65"

# --- Supabase — service role (pipeline + cron; $env/dynamic/private) ---
SUPABASE_SERVICE_ROLE_KEY="***************************"
SUPABASE_URL="***************************"

# --- Supabase — public anon (homepage SSR + RLS; $env/dynamic/public) ---
PUBLIC_SUPABASE_ANON_KEY="***************************"
PUBLIC_SUPABASE_URL="***************************"

# --- X / Twitter API v2 Basic (Recent Search) ---
X_BEARER_TOKEN="***************************"

# --- GitHub Actions cron (append to ?secret= on the route) ---
CRON_SECRET="***************************"
BREAKING_SECRET="***************************"

# --- Homepage (RFC-002) — optional ($env/dynamic/private) ---
# USE_MOCK_DATA: exact "true" enables mock digest (mock-data.ts); local dev only
USE_MOCK_DATA="false"
# DIGEST_FUSE_THRESHOLD: Fuse.js threshold; default 0.4 if unset or invalid
DIGEST_FUSE_THRESHOLD="0.4"
