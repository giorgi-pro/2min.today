# Gemini (text + embeddings) — ADR-001
GEMINI_API_KEY=

# Supabase (pgvector + storage) — service role: pipeline + cron only ($env/dynamic/private)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — public anon (homepage SSR load + RLS; safe to expose; $env/dynamic/public)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# X / Twitter API v2 Basic tier (Recent Search)
X_BEARER_TOKEN=

# Vercel Cron secret (appended to /api/digest?secret=)
CRON_SECRET=

# Homepage (RFC-002) — optional; read in +page.server.ts ($env/dynamic/private)
# Exact string "true" only — enables mock digest from mock-data.ts (no Supabase); local dev
USE_MOCK_DATA=
# Fuse.js threshold for client search; default 0.4 if unset or invalid
DIGEST_FUSE_THRESHOLD=
