# Gemini (text + embeddings) — ADR-001
GEMINI_API_KEY=

# Supabase (pgvector + storage) — service role: pipeline + cron only ($env/dynamic/private)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — public anon (homepage SSR load + RLS; safe to expose; $env/dynamic/public)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Optional: Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
